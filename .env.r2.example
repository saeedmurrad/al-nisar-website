# Cloudflare R2 credentials — copy to .env.r2 (never commit .env.r2)
R2_ACCOUNT_ID=
R2_BUCKET_NAME=al-nisar-audio
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# Public r2.dev URL after enabling bucket public access (no trailing slash)
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
